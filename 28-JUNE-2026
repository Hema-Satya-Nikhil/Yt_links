#include <iostream>
#include <vector>
using namespace std;

struct Node {
    int cnt[8];
    int lazy;
    Node() {
        for (int i = 0; i < 8; i++) cnt[i] = 0;
        lazy = 0;
    }
};
vector<Node> seg;
Node merge(Node &a, Node &b) {
    Node res;
    for (int i = 0; i < 8; i++)
        res.cnt[i] = a.cnt[i] + b.cnt[i];
    return res;
}

void apply(int idx, int mask) {
    int temp[8] = {0};
    for (int i = 0; i < 8; i++)
        temp[i ^ mask] = seg[idx].cnt[i];

    for (int i = 0; i < 8; i++)
        seg[idx].cnt[i] = temp[i];

    seg[idx].lazy ^= mask;
}

void push(int idx) {
    if (seg[idx].lazy) {
        apply(2 * idx, seg[idx].lazy);
        apply(2 * idx + 1, seg[idx].lazy);
        seg[idx].lazy = 0;
    }
}
void build(int idx, int l, int r, vector<int> &a) {
    if (l == r) {
        seg[idx].cnt[a[l]] = 1;
        return;
    }
    int mid = (l + r) / 2;
    build(2 * idx, l, mid, a);
    build(2 * idx + 1, mid + 1, r, a);
    seg[idx] = merge(seg[2 * idx], seg[2 * idx + 1]);
}
void update(int idx, int l, int r, int ql, int qr, int mask) {
    if (qr < l || r < ql) return;

    if (ql <= l && r <= qr) {
        apply(idx, mask);
        return;
    }

    push(idx);
    int mid = (l + r) / 2;
    update(2 * idx, l, mid, ql, qr, mask);
    update(2 * idx + 1, mid + 1, r, ql, qr, mask);

    seg[idx] = merge(seg[2 * idx], seg[2 * idx + 1]);
}
Node query(int idx, int l, int r, int ql, int qr) {
    if (qr < l || r < ql) return Node();

    if (ql <= l && r <= qr) return seg[idx];

    push(idx);
    int mid = (l + r) / 2;
    Node left = query(2 * idx, l, mid, ql, qr);
    Node right = query(2 * idx + 1, mid + 1, r, ql, qr);

    return merge(left, right);
}
vector<int> process_events(int n, int q, vector<int>& receptors, vector<vector<int>>& events) {
    seg.resize(4 * n);
    build(1, 0, n - 1, receptors);
    vector<int> ans;
    for (auto &e : events) {
        if (e[0] == 1) {
            update(1, 0, n - 1, e[1] - 1, e[2] - 1, e[3]);
        } else {
            Node res = query(1, 0, n - 1, e[1] - 1, e[2] - 1);

            int mx = 0;
            for (int i = 0; i < 8; i++)
                mx = max(mx, res.cnt[i]);

            ans.push_back(mx);
        }
    }

    return ans;
}
int main() {
    int n, q;
    cin >> n >> q;
    vector<int> receptors(n);
    for (int i = 0; i < n; ++i) {
        cin >> receptors[i];
    }

    vector<vector<int>> events(q);
    for (int i = 0; i < q; ++i) {
        int type;
        cin >> type;
        if (type == 1) {
            int l, r, m;
            cin >> l >> r >> m;
            events[i] = {type, l, r, m};  // Type 1: XOR update
        } else if (type == 2) {
            int l, r;
            cin >> l >> r;
            events[i] = {type, l, r};     // Type 2: Query
        }
    }

    vector<int> results = process_events(n, q, receptors, events);
    for (int result : results) {
        cout << result << endl;
    }

    return 0;
}
