#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

long long minimumWaves(vector<long long>& diff)
{
    int n = diff.size();
    long long operations = 0;
    int i = 0;

    while (i < n)
    {
        if (diff[i] == 0)
        {
            i++;
            continue;
        }

        int sign = (diff[i] > 0) ? 1 : -1;
        long long previous = 0;

        while (i < n && diff[i] * sign > 0)
        {
            long long current = llabs(diff[i]);

            if (current > previous)
            {
                operations += current - previous;
            }

            previous = current;
            i++;
        }
    }

    return operations;
}

int main()
{
    int n;
    cin >> n;

    vector<long long> E(n), T(n), diff(n);

    for (int i = 0; i < n; i++)
    {
        cin >> E[i];
    }

    for (int i = 0; i < n; i++)
    {
        cin >> T[i];
        diff[i] = T[i] - E[i];
    }

    cout << minimumWaves(diff) << endl;

    return 0;
}
